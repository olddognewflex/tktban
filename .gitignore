# Go build output
/tktban
*.out
# leftover Python artifacts (the implementation was ported to Go; these guard
# against stray files from an old venv/build lingering on a dev machine)
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
.pytest_cache/
# repo-root .sdlc is generated per-machine by odnf/.sdlc/_gen_configs.py (absolute
# paths) — leading slash so it does NOT match anything committed under the repo
/.sdlc/
# local agent scratch (subagent memory etc.) — never part of the repo
.claude/agent-memory/
